# YouTube Data API Configuration
# Get your API key from: https://console.developers.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: OAuth2 credentials for authenticated requests
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://localhost:3000/oauth2callback

# Spotify Web API Configuration
# Get your credentials from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_SECRET=your_spotify_client_secret_here

# Chartmetric API Configuration
# Get your refresh token from: https://api.chartmetric.com/
CHARTMETRICS_API_KEY=your_chartmetric_refresh_token_here

# Cloudflare R2 Storage Configuration (Optional)
# Required for screenshot storage with storage_provider=cloudflare
# Get credentials from: https://dash.cloudflare.com/
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET=your_r2_bucket_name_here
R2_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev
